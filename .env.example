# GNews API key for the News layer (get a free key at https://gnews.io/)
VITE_GNEWS_API_KEY=your_gnews_api_key_here

# Google Maps JavaScript API key for 360° Street View (drag to look around)
# Enable "Maps JavaScript API" in Google Cloud Console: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Mapbox access token for bird's-eye 3D view when zoomed in (3D buildings + optional traffic)
# Get a token at https://account.mapbox.com/ ; without this, zoomed-in view uses flat Leaflet map
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Optional: 24/7 news LIVE broadcast (YouTube video ID). Use a channel's current live stream ID
# (e.g. Al Jazeera English, DW News, Sky News). Find it on the channel's Live tab or watch URL.
VITE_NEWS_LIVE_YOUTUBE_ID=
